{
  "_doc": "하니스 외부 구조화 메모리 스키마 (설계 A §4, §P6). 채팅 컨텍스트가 아닌 이 원장에 상태를 보존하고, 각 에이전트는 필요한 슬라이스만 읽는다.",

  "failure_ledger": {
    "_key": "case + commit + variant",
    "fields": {
      "case": "TV2C005",
      "commit": "engine git sha",
      "variant": "ue-DebugGame-x64",
      "verdict": "PASS|FAIL|ERROR",
      "missing": ["dfb_source_A.ret"],
      "forbidden_found": ["dfb_source_B.ret"],
      "cut": ["OBSERVED_MEMORY:..."],
      "root_cause_ref": "hypothesis_ledger.id"
    },
    "_use": "케이스별 verdict 이력 + 회귀 추적 + 재진단 방지"
  },

  "hypothesis_ledger": {
    "_key": "id",
    "fields": {
      "id": "H-001",
      "claim": "self 포인터 store가 unknown 셀로 뭉개져 옆 field 오매칭",
      "evidence_ref": "diagnose dump path / failure_report key",
      "status": "proposed|refuted|confirmed|fixed",
      "adversary_votes": {"correctness": "confirm", "regression": "confirm", "fp_risk": "confirm"}
    },
    "_use": "신뢰의 원장 — '검증됨 vs 가설' 관장. confirmed/fixed만 사실로 승격(A §P2). 증거 없는 claim 금지."
  },

  "decision_log": {
    "_key": "engine_change(sha)",
    "fields": {
      "change": "engine git sha / PR",
      "why": "한 줄 근거",
      "cites": ["failure_ledger keys"],
      "evidence": "재현 명령/덤프",
      "adversary_votes": "패널 결과",
      "objective_delta": "before→after 목적벡터"
    },
    "_use": "엔진 수정 provenance. 모든 변경은 인용된 실패+증거에 묶인다(A §P4)."
  },

  "artifact_cache": {
    "_doc": "계층 캐시 4단 (설계 v2 §5). 단일 평면키 금지 — 과잉 무효화 방지.",
    "build_artifact":  { "key": ["source_hash", "toolchain", "build_variant"], "value": "binary_path" },
    "pcode_metadata":  { "key": ["binary_hash", "ghidra_version", "extractor_hash", "metadata_schema_version"], "value": ["pcode_path", "metadata_path"] },
    "engine_result":   { "key": ["pcode_hash", "metadata_hash", "engine_commit", "run_config_hash"], "value": "result_path" },
    "verify_result":   { "key": ["engine_result_hash", "expected_hash", "verifier_version"], "value": "verdict" },
    "prepare_step":    { "key": ["command", "tool_env", "input_hashes", "outputs"], "value": "prepare_report row" },
    "_invalidation": "source→build부터 / extractor→pcode부터 / engine_commit→engine_result부터 / expected→verify만",
    "_note": "비교·해시 전 canonical JSON 정규화(키·node·edge 정렬). 엔진 출력 결정성 PR3서 검증(2회→동일 해시)."
  },

  "baseline_map": {
    "_key": "variant_label",
    "fields": {
      "variant": "arch/compiler/opt/build_config/source_kind",
      "summary": "latest observed pass/fail/error/fp/cache counts",
      "cases": {"TV2R001": {"verdict": "PASS|FAIL|ERROR", "missing": [], "forbidden_found": []}},
      "gate": "latest deterministic gate",
      "run_id": "harness run id",
      "output_root": "artifact directory"
    },
    "_use": "release/local/UE Mac baseline을 expected와 분리해 관측 결과로 관리한다. 오라클이 아니며, 엔진 출력에서 expected를 만들지 않는다."
  },

  "capability_map": {
    "_key": "case_class",
    "fields": {
      "case_class": "deep_field_pointer_passthrough",
      "status": "can|cannot|frontier|missing|weakly_covered|contradictory",
      "cases": ["..."],
      "note": "DFB055 계열, 2+deref",
      "blocking_hypothesis": "hypothesis_ledger.id"
    },
    "_use": "frontier를 회귀로 오인해 두드리지 않게(gate known_frontier_not_counted). contradictory는 human escalation·자동수정 금지(설계 v2 §8)."
  },

  "human_approval_queue": {
    "_key": "append-only",
    "fields": {
      "run_id": "harness run id",
      "kind": "oracle_change|crash_or_harness_error|false_positive|frontier_candidate",
      "severity": "hard|review",
      "case": "case id",
      "variant": "variant label",
      "evidence_ref": "failure_report_v2.json path",
      "required_action": "what a human must approve or decide"
    },
    "_use": "오라클 변경, FP, crash, frontier 후보를 자동으로 승인하지 않고 사람이 볼 큐에 남긴다."
  },

  "human_decisions": {
    "_key": "approval item key",
    "fields": {
      "key": "stable queue item key",
      "decision": "approve|reject|defer",
      "actor": "human/operator id",
      "reason": "why this decision was made",
      "capability_status": "optional can|cannot|frontier|missing|weakly_covered|contradictory",
      "queue_item": "original queue payload"
    },
    "_use": "큐 항목을 삭제하지 않고 append-only 결정 원장으로 승인/반려/보류를 기록한다. capability_status가 있으면 capability_map에 human decision ref를 남긴다."
  },

  "baseline_pins": {
    "_key": "pin name",
    "fields": {
      "name": "stable baseline name",
      "run_id": "harness run id",
      "report_path": "failure_report_v2.json path",
      "report_hash": "sha256",
      "description": "why this baseline is pinned"
    },
    "_use": "I3 regression gate에서 사람이 선택한 기준 run을 이름으로 참조한다. baseline은 observed result이지 expected/oracle이 아니다."
  },

  "proposal_artifacts": {
    "_key": "output/harness/<run_id>/proposal_manifest.json or proposed_cases/<run_id>/proposal_manifest.json",
    "fields": {
      "kind": "proposed_case|engine_fix_proposal|coverage_update_proposal",
      "agent_result": "validated accepted agent result row",
      "proposal": "agent output payload",
      "work_items": "optional source skeleton / engine fix plan / coverage update plan review artifacts",
      "policy": "expected_not_applied / engine_not_modified / requires_human_approval"
    },
    "_use": "accepted agent output을 사람이 검토할 proposal/work_item으로만 materialize한다. expected/manifest/engine main은 직접 수정하지 않는다."
  }
}
